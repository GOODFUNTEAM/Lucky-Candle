<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>燭籤 Lucky Candle | 孤芳小隊</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
</head>
<body>
    <div class="global-container">
        <div id="stage-init" class="stage">
            <img src="candle_full.png" alt="燭籤" class="full-candle clickable" onclick="startAnimation()">
            <p class="hint">點擊蠟燭，開啟願望</p>
        </div>

        <div id="stage-interact" class="stage hidden">
            <div class="candle-split-wrapper">
                <img src="candle_top.png" class="candle-part top">
                <div class="white-light"></div>
                <img src="candle_bottom.png" class="candle-part bottom">
            </div>
            <div id="slips-container" class="slips-grid"></div>

            <div id="input-overlay" class="overlay hidden">
                <div class="input-box">
                    <h3>最後一個願望，留給自己</h3>
                    <textarea id="custom-wish" placeholder="請在此填入你的願望..."></textarea>
                    <button onclick="confirmCustomWish()">確定</button>
                </div>
            </div>
        </div>

        <div id="stage-summary" class="stage hidden">
            <div id="download-zone">
                <div id="final-slips" class="slips-grid"></div>
                <p class="summary-footer">孤芳小隊 - 燭籤 Lucky Candle</p>
            </div>
            <div class="action-buttons">
                <button onclick="downloadShot()" class="btn-download">下載畫面</button>
                <button onclick="wishing()" class="btn-wish">許願</button>
            </div>
        </div>

        <div id="stage-finish" class="stage hidden">
            <img src="finish.png" alt="心想事成" class="finish-img">
            <button onclick="resetAll()" class="btn-again">再來一次</button>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
